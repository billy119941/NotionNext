# Cloudflare R2 图片上传配置示例
# 复制此文件为 .env.local 并填入实际的配置值

# R2上传API端点 (需要自己搭建或使用第三方服务)
R2_UPLOAD_ENDPOINT=https://your-upload-api.example.com/upload

# R2 API密钥
R2_API_KEY=your-r2-api-key-here

# R2存储桶配置
R2_BUCKET_NAME=your-bucket-name
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# 图片域名 (已配置为 image.shareking.vip)
R2_DOMAIN=image.shareking.vip

# WebP转换配置
WEBP_QUALITY=80
WEBP_ENABLE_AUTO_CONVERSION=true

# 注意：
# 1. 由于R2不直接支持HTTP上传，你需要：
#    - 搭建一个上传API服务 (如使用Cloudflare Workers)
#    - 或使用现有的图片上传服务
# 2. 当前实现会在没有配置上传端点时使用模拟上传
# 3. 图片映射关系会存储在缓存中，供渲染时使用